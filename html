<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Entradas com Botão</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;

      display: flex;
      flex-direction: column;
      align-items: center;
      height: 100vh;
    }

    h1 {
      margin-top: 20px;
    }

    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .campo {
      margin: 20px 0; /* mais espaço entre as divs */
      padding: 20px;
      border-radius: 10px;
      width: 350px;
      text-align: center;
      color: white;
    }

    /* cores diferentes */
    .campo:nth-child(1) {
      background-color: #3498db; /* azul */
    }

    .campo:nth-child(2) {
      background-color: #2ecc71; /* verde */
    }

    .campo:nth-child(3) {
      background-color: #e74c3c; /* vermelho */
    }

    input {
      padding: 8px;
      width: 90%;
      font-size: 14px;
      margin-bottom: 10px;
      text-align: center;
      border: none;
      border-radius: 5px;
    }

    button {
      padding: 6px 12px;
      cursor: pointer;
      border: none;
      border-radius: 5px;
    }
  </style>
</head>
<body>

  <h1>Desafio Ford</h1>

  <div class="container">
    <div class="campo">
      <label>Qual é a distancia pecorrida da sua casa até o seu trabalho(em km)?</label><br>
      <input type="text" oninput="somenteNumeros(this)">
      <br>
      <button onclick="enviar(this)">Enviar</button>
    </div>

    <div class="campo">
      <label>Qual o consumo medio do seu veiculo(em km/l)?</label><br>
      <input type="text" oninput="somenteNumeros(this)">
      <br>
      <button onclick="enviar(this)">Enviar</button>
    </div>

    <div class="campo">
      <label>Em quantos postos voce pesquisou?</label><br>
      <input type="text" oninput="somenteNumeros(this)">
      <br>
      <button onclick="enviar(this)">Enviar</button>
    </div>
  </div>

  <script>
    function somenteNumeros(campo) {
      campo.value = campo.value.replace(/[^0-9.]/g, '');
    }

    function enviar(botao) {
      const input = botao.parentElement.querySelector("input");

      if (input.value.trim() === "") {
        alert("Por favor, preencha o campo antes de enviar.");
        return;
      }

      alert("Valor enviado: " + input.value);
    }
  </script>

</body>
</html>